# ============================================
# Walkie Talkie Backend — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.

# --- Database ---
# Path to SQLite database file (default: ./inventory.db)
DATABASE_PATH=./inventory.db

# --- Copilot Studio (Direct Line) ---
# Get this from Copilot Studio: Settings → Security → Web channel security
DIRECTLINE_SECRET=your_direct_line_secret_here

# --- Speech-to-Text ---
# Whisper model size: tiny | base | small | medium | large-v2
WHISPER_MODEL=base

# --- Text-to-Speech ---
# Microsoft Edge TTS voice (see: https://speech.microsoft.com/portal)
TTS_VOICE=en-IN-NeerjaNeural

# --- API Security ---
# API key for authenticating tool calls from Copilot Studio
API_KEY=your_api_key_here
